# .env.example
# Your Wallet Private Key for signing transactions (Keep this secret!)
WALLET_PRIVATE_KEY=

# RPC URLs (Optional if you want to use your own providers)
RPC_URL_ETH=https://eth.llamarpc.com
RPC_URL_BSC=https://binance.llamarpc.com
RPC_URL_POLYGON=https://polygon.llamarpc.com
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc

# API Key for Knowledge Base
BLOCKCHAIN_API_KEY=
